# ─── DATABASE ───────────────────────────────────────────
# Paste your PostgreSQL connection string here
# Format: postgresql://user:password@host:port/dbname
# Example (local):   postgresql://postgres:password@localhost:5432/cropwise_db
# Example (Supabase): postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Example (Neon):     postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cropwise_db
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DB

# ─── GOOGLE EARTH ENGINE ────────────────────────────────
# GEE project ID — already working from the ML team's scripts
GEE_PROJECT_ID=cropwise-ai-499810

# Optional: service account for production deployment
# Leave empty to use saved user credentials (ee.Authenticate())
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=

# ─── SECURITY ───────────────────────────────────────────
# Must match INTERNAL_API_KEY in cropwise-ui/proxy-server/.env
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=replace_with_long_random_string

# Origins allowed to call this API (the proxy server URL)
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5173

# ─── BEHAVIOUR ──────────────────────────────────────────
# true  = return mock tile URLs and data when GEE is unavailable
# false = always call GEE (fail if GEE is down)
USE_MOCK_GEE=true

# true  = cache GEE tile URLs in PostgreSQL for 24 hours
#         (GEE tile URL generation takes 30-60 seconds,
#          caching makes subsequent calls instant)
CACHE_TILES=true

# How long to cache tile URLs before regenerating (seconds)
CACHE_TTL_SECONDS=86400
