# ─── DATABASE (REQUIRED) ───────────────────────────────────────────
# For testing: Use SQLite (no PostgreSQL needed)
# For production: Replace with your PostgreSQL connection string
DATABASE_URL=sqlite:///./cropwise_test.db

# ─── SECURITY (REQUIRED) ───────────────────────────────────────────
# Generated key for API validation
INTERNAL_API_KEY=test_key_12345678901234567890123456789012

# ─── GOOGLE EARTH ENGINE ────────────────────────────────────────────
# GEE Project ID
GEE_PROJECT_ID=cropwise-ai-499810

# ─── BEHAVIOR FLAGS ───────────────────────────────────────────────
# Use mock GEE (no authentication needed for testing)
USE_MOCK_GEE=true

# Cache tile URLs for 24 hours
CACHE_TILES=true
CACHE_TTL_SECONDS=86400

# CORS origins
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5173
